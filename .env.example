# ----------------------------------------------------------------------------
# Élan Patrimoine — variables d'environnement
# Copier ce fichier en `.env.local` et renseigner les valeurs réelles.
# Toutes ces variables sont OPTIONNELLES : sans elles, le site fonctionne
# en mode développement (e-mails journalisés, analytics désactivée).
# ----------------------------------------------------------------------------

# Webhook n8n recevant les soumissions (contact + newsletter).
# Sans cette URL, les soumissions sont seulement journalisées (mode développement).
N8N_WEBHOOK_URL=https://n8n.srv1019025.hstgr.cloud/webhook/5848f992-588f-4de9-990f-8f50007d4073
# Secret optionnel pour l'authentification du webhook n8n.
N8N_WEBHOOK_TOKEN=
# Nom de l'en-tête d'authentification (défaut : Authorization, envoyé en "Bearer <token>").
# Pour un en-tête personnalisé n8n (Header Auth), indiquez son nom, ex : x-n8n-secret.
N8N_WEBHOOK_HEADER=

# Webhook n8n du chatbot (pages Contact et Nos Expertises). DOIT répondre
# de façon synchrone (nœud "Respond to Webhook") avec la réponse de l'assistant.
# La réponse peut être du texte brut ou un JSON { "reply" | "output" | "text": "..." }.
# Sans cette URL, le chatbot fonctionne en mode démonstration.
N8N_CHAT_WEBHOOK_URL=https://n8n.srv1019025.hstgr.cloud/webhook/d156816b-d3fa-48d7-8ca1-5c38a4384b81
# Auth optionnelle (défaut : reprend N8N_WEBHOOK_TOKEN / N8N_WEBHOOK_HEADER si absents).
N8N_CHAT_WEBHOOK_TOKEN=
N8N_CHAT_WEBHOOK_HEADER=

# Analytics respectueuse de la vie privée (Plausible). Domaine du site.
# Laisser vide pour désactiver complètement le suivi.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# URL du script Plausible (défaut : https://plausible.io/js/script.js)
NEXT_PUBLIC_PLAUSIBLE_SRC=

# ----------------------------------------------------------------------------
# Sanity (CMS) — administration du contenu sur /studio
# ----------------------------------------------------------------------------
# Identifiant du projet Sanity (visible sur https://www.sanity.io/manage).
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Jeu de données (en général "production").
NEXT_PUBLIC_SANITY_DATASET=production
# Version de l'API Sanity (date). Laisser tel quel sauf besoin précis.
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Jeton d'écriture (rôle "Editor"), UNIQUEMENT pour le script d'import initial
# (`npm run seed`). Ne pas exposer côté client. À créer dans Sanity > API > Tokens.
SANITY_API_WRITE_TOKEN=
# Jeton de LECTURE (rôle "Viewer") — nécessaire UNIQUEMENT si le dataset est
# privé. Lu côté serveur seulement. Laisser vide si le dataset est public
# (recommandé pour un site vitrine).
SANITY_API_READ_TOKEN=
